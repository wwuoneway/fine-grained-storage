# =========================
# Build directories
# =========================
build/

# =========================
# Logs / runtime outputs
# =========================
*.log

# =========================
# Python
# =========================
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/

# =========================
# Editor / machine-specific
# =========================
# IntelliSense config with absolute compiler paths — local to each machine.
# .vscode/settings.json IS shared and tracked; c_cpp_properties.json is not.
.vscode/c_cpp_properties.json

# =========================
# OS files
# =========================
.DS_Store
Thumbs.db

# =========================
# Temporary files
# =========================
*.tmp
*.temp
*.swp

# Documentation for internal development, not needed in the repository
docs.me/

# =========================
# Generated benchmark data
# =========================
# Phase 1 writes all synthetic input data under output/ (configurable via the
# "output_dir" config key). It is generated at runtime and must never be
# committed.
output/

# CMake build trees (also covered by build/ above, listed here for clarity).
build/